# Prefer a TOML config file for persistent settings:
#   pais config init                # writes ~/.pais/config.toml
#   pais config init --project      # writes ./pais.toml
# Use `pais --profile <name>` to switch environments.
# Env vars below still work and override the config file.

# --- Mock mode (no real host needed) ---
PAIS_MODE=mock

# --- Real PAIS, internal network, no auth, self-signed cert ---
# PAIS_MODE=http
# PAIS_BASE_URL=https://pais.internal/api/v1
# PAIS_AUTH=none
# PAIS_VERIFY_SSL=false

# --- Real PAIS with OIDC (public/hosted) ---
# PAIS_MODE=http
# PAIS_BASE_URL=https://pais.example.com/api/v1
# PAIS_AUTH=oidc_password
# PAIS_OIDC_ISSUER=https://pais.example.com
# PAIS_CLIENT_ID=pais-cli
# PAIS_USERNAME=your-username
# PAIS_PASSWORD=your-password

# --- Static bearer token ---
# PAIS_AUTH=bearer
# PAIS_BEARER_TOKEN=...

# --- Index-creation hints for the test-suite ingestion use case ---
# chunk_size and chunk_overlap are measured in TOKENS (not chars).
# 512 / 64 is the recommended combo with the pais-dev splitter
# (splitter emits files <= 400 tokens, leaving 112-token headroom).
# PAIS_INDEX_CHUNK_SIZE=512
# PAIS_INDEX_CHUNK_OVERLAP=64

# --- Tuning ---
# PAIS_LOG_LEVEL=DEBUG
# PAIS_CONNECT_TIMEOUT=5
# PAIS_READ_TIMEOUT=60
# PAIS_TOTAL_TIMEOUT=120
# PAIS_RETRY_MAX_ATTEMPTS=4
# PAIS_CHAT_COLD_START_RETRIES=3
